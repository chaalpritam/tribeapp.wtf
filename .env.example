# tribeapp.wtf — local demo defaults
# This build runs entirely off in-repo seed data; no API keys required.

# Set to "true" to load seed/mock data (default for tribeapp.wtf demo).
NEXT_PUBLIC_SEED_DATA=true

# Optional Farcaster integration — leave blank to stay on seed data.
NEYNAR_API_KEY=
NEXT_PUBLIC_NEYNAR_CLIENT_ID=

# XMTP Environment ("dev" | "production" | "local")
NEXT_PUBLIC_XMTP_ENV=production

# Tribe protocol — leave defaults to talk to local dev nodes,
# or override to point at a deployed seed/hub.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_HUB_URL=http://localhost:4000
NEXT_PUBLIC_ER_SERVER_URL=http://localhost:3003
# Optional comma-separated lists for multi-node failover.
NEXT_PUBLIC_HUB_URLS=
NEXT_PUBLIC_ER_SERVER_URLS=
